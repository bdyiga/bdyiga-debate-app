{
  "name": "ld-debate-tournament",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node server/index.js",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "prisma:migrate": "npx prisma migrate dev --name init",
    "prisma:generate": "npx prisma generate",
    "seed": "node prisma/seed.js",
    "setup": "npx prisma migrate dev --name init && node prisma/seed.js",
    "deploy:gh-pages": "vite build && npx gh-pages -d dist",
    "postinstall": "npx prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "@prisma/client": "^5.22.0",
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "iron-session": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "vite": "^5.4.0",
    "@vitejs/plugin-react": "^4.3.0",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "gh-pages": "^6.2.0"
  }
}
